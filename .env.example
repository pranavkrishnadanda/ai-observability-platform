# Database
DATABASE_URL=postgresql+asyncpg://aiobs:aiobs_secret@postgres:5432/aiobs_db

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Security
SECRET_KEY=your-32-char-minimum-secret-key-here

# Rate limiting
RATE_LIMIT_PER_MINUTE=1000
ALERT_RATE_LIMIT_PER_HOUR=10

# Anomaly detection
ANOMALY_CHECK_INTERVAL=30
ANOMALY_VOLUME_SPIKE_MULTIPLIER=2.5
ANOMALY_VOLUME_DROP_MULTIPLIER=0.2
ANOMALY_ERROR_RATE_MULTIPLIER=3.0

# Log retention
LOG_RETENTION_HOT_HOURS=1
LOG_RETENTION_COLD_DAYS=90

# Claude
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_TIMEOUT=30
CLAUDE_MAX_CONCURRENT=10

# Application
DEBUG=false
